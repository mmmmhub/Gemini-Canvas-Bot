# ─── Gemini Canvas Automation – Environment Config ───────────────────────────
#
# Copy this file to .env and fill in your values.
# Alternatively, export a cookies.json file (see README) and leave this blank.

# ─── Target ───────────────────────────────────────────────────────────────────
TARGET_URL=https://share.gemini.google/EIt5nvt7wCXV

# ─── Input ────────────────────────────────────────────────────────────────────
# Absolute or relative path to the image you want to upload
IMAGE_PATH=./input.jpg

# Text prompt to enter in the generation field
PROMPT=A beautiful sunset over the mountains

# Number of output images to request
OUTPUT_COUNT=1

# ─── Output ───────────────────────────────────────────────────────────────────
# Directory where the result image(s) will be saved
OUTPUT_DIR=./output

# ─── Auth (option A – raw cookie string) ─────────────────────────────────────
# Paste the full Cookie: header value from your browser DevTools here.
# Only needed if you are NOT using cookies.json.
COOKIE_STRING=

# ─── Browser ──────────────────────────────────────────────────────────────────
# Set to "true" to run with a visible browser window (useful for debugging)
HEADLESS=true

# Maximum milliseconds to wait for the download button after clicking start
PROCESS_TIMEOUT_MS=120000
